<aml version="0.2" profile="masfactory" kind="library" id="applications.chatdev.pure_aml.simple_phases" lang="zh-CN">
  <imports>
    <import alias="common" src="../common.aml" />
  </imports>

  <definitions>
    <agents>
      <agent id="demand_analysis_instructor" name="Chief Executive Officer" role="instructor">
        <model ref="common::chat_model" />
        <instructions format="markdown">
          <include source="common::phase_config" key="DemandAnalysis.phase_prompt" />
          <include source="common::role_config" key="Chief Executive Officer" />
        </instructions>
        <memories><use ref="common::demand_analysis_memory" /></memories>
      </agent>
      <agent id="demand_analysis_assistant" name="Chief Product Officer" role="assistant">
        <model ref="common::chat_model" />

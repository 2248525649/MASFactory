            </edges>
          </loop>
          <custom_node id="post_processor" forward="python:applications.chatdev.components.phase.handlers.codes_check_and_processing"><arguments><arg value="Finish Coding!" /></arguments></custom_node>
        </nodes>
        <edges>
          <edge from="entry" to="pre_processor"><keys /></edge>

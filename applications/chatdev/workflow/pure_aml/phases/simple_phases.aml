        <memories><use ref="common::manual_memory" /></memories>
      </agent>
    </agents>

    <graphs>
      <graph id="demand_analysis_phase">
        <attributes>
          <pull_keys mode="keys">
            <field name="task" type="string" />
            <field name="description" type="string" />
            <field name="chatdev_prompt" type="string" />
            <field name="discussion_opinion" type="string" />
          </pull_keys>
          <push_keys mode="keys">
            <field name="discussion_opinion" type="string" />
            <field name="modality" type="string" />
          </push_keys>
        </attributes>
        <nodes>
          <custom_node id="pre_processor" forward="builtin:noop" />
          <loop id="role_playing" max_iterations="19">
            <terminate if="discussion_finished == true" />
            <nodes>
              <logic_switch id="turn_switch" />
              <agent id="instructor" ref="#demand_analysis_instructor" />
              <agent id="assistant" ref="#demand_analysis_assistant" />
            </nodes>
            <edges>
              <edge from="controller" to="turn_switch"><keys /></edge>
              <edge from="turn_switch" to="instructor" if="current_iteration % 2 == 1"><keys /></edge>
              <edge from="turn_switch" to="assistant" if="current_iteration % 2 == 0"><keys /></edge>
              <edge from="instructor" to="controller"><keys /></edge>
              <edge from="assistant" to="controller"><keys /></edge>
            </edges>
          </loop>
          <custom_node id="post_processor" forward="builtin:noop" />
        </nodes>
        <edges>
          <edge from="entry" to="pre_processor"><keys /></edge>
          <edge from="pre_processor" to="role_playing"><keys /></edge>
          <edge from="role_playing" to="post_processor"><keys /></edge>
          <edge from="post_processor" to="exit"><keys /></edge>
        </edges>
      </graph>

